#! /bin/bash
# aldc: Add LaTeX DevContainer

REPOSITORY_NAME='latex-environment'
REPOSITORY_OWNER='smkwlab'
REPOSITORY_URL="https://github.com/${REPOSITORY_OWNER}/${REPOSITORY_NAME}"
BRANCH='release'
ZIP_NAME="${REPOSITORY_NAME}-${BRANCH}.zip"

# Files to exclude from latex-environment integration
# These workflows are designed for latex-environment development and are not
# suitable for thesis/document repositories
EXCLUDE_PATTERNS=(
    ".github/workflows/branch-cleanup.yml"
    ".github/workflows/pr-auto-cleanup.yml"
    ".github/workflows/check-texlive-updates.yml"
    ".github/workflows/update-release-branch.yml"
)

TARGET=${REPOSITORY_URL}/archive/refs/heads/${BRANCH}.zip

# Parse command line arguments for quiet mode
QUIET=false
if [ "${ALDC_QUIET:-}" = "1" ]; then
    QUIET=true
fi

while [ $# -gt 0 ]; do
    case $1 in
        --quiet|-q)
            QUIET=true
            shift
            ;;
        --help|-h)
            echo "Usage: aldc [--quiet|-q] [--help|-h]"
            echo ""
            echo "Add LaTeX DevContainer to the current directory."
            echo ""
            echo "Options:"
            echo "  --quiet, -q     Suppress output messages"
            echo "  --help, -h      Show this help message"
            echo ""
            echo "Environment Variables:"
            echo "  ALDC_QUIET=1    Enable quiet mode"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Use --help for usage information" >&2
            exit 1
            ;;
    esac
done

# Logging function
log() {
    if [ "$QUIET" = "false" ]; then
        echo "$1"
    fi
}

if [ -d .devcontainer ]; then
  log "The LaTeX environment already exists."
  exit
fi

GIT_INIT=false
if [ ! -d .git ]; then
  if [ "$QUIET" = "false" ]; then
    git init .
    git add .
    # aldcファイルが存在する場合のみ除外
    if git ls-files --cached | grep -q "^aldc$"; then
      git rm --cached aldc
    fi
    git commit -m "initial commit"
  else
    git init . >/dev/null 2>&1
    git add . >/dev/null 2>&1
    # aldcファイルが存在する場合のみ除外
    if git ls-files --cached | grep -q "^aldc$"; then
      git rm --cached aldc >/dev/null 2>&1
    fi
    git commit -m "initial commit" >/dev/null 2>&1
  fi
  GIT_INIT=true
fi

log "download LaTeX environment"
if ! curl -fsSLJO "${TARGET}"; then
    echo "Error: failed to download LaTeX environment from ${TARGET}" >&2
    rm -f "${ZIP_NAME}"
    exit 1
fi
if ! unzip -q "${ZIP_NAME}"; then
    echo "Error: failed to extract ${ZIP_NAME}" >&2
    rm -f "${ZIP_NAME}"
    exit 1
fi
rm -f "${ZIP_NAME}"
cd "${REPOSITORY_NAME}-${BRANCH}" || {
    echo "Error: extracted directory ${REPOSITORY_NAME}-${BRANCH} not found" >&2
    exit 1
}

# Remove excluded files before integration
log "Applying file exclusions..."
for pattern in "${EXCLUDE_PATTERNS[@]}"; do
    if [ -f "$pattern" ]; then
        rm -f "$pattern"
        log "  Excluded: $pattern"
    fi
done

log "Integrate LaTeX environment"
backups=""
for i in $(find . -type f); do
    if [ -e ../${i} ]; then
        mv -f ${i} ../${i}-aldc
        backups="${backups} ${i}-aldc"
    else
        dir=../$(dirname ${i})
        if [ ! -d ${dir} ]; then
            mkdir -p ${dir}
        fi
        mv -f ${i} ../${i}
    fi
done

cd .. || {
    echo "Error: failed to return to parent directory" >&2
    exit 1
}
rm -rf "${REPOSITORY_NAME}-${BRANCH}"

if [ "$QUIET" = "false" ]; then
    git add .
    git diff --cached --quiet || git commit --quiet -m "add LaTeX environment"
else
    git add . >/dev/null 2>&1
    git diff --cached --quiet || git commit --quiet -m "add LaTeX environment" >/dev/null 2>&1
fi
# [ "${GIT_INIT}" != "true" ] && git push --quiet

log "The LaTeX environment integration is complete."

if [ "${backups}" != "" ]; then
    log "You may delete the following files: ${backups}"
fi
